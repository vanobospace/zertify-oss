APP_NAME=Zertify
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=zertify
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI generation is optional. Leave these empty to run the app without generation.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_REQUEST_TIMEOUT_SECONDS=60
GEMINI_CONNECT_TIMEOUT_SECONDS=10
GEMINI_EXPLANATION_TIMEOUT_SECONDS=45
GEMINI_REQUEST_BUDGET_SECONDS=120
GEMINI_MAX_GENERATION_ATTEMPTS=3

# Optional Google Cloud Text-to-Speech integration.
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON=
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_CLOUD_TTS_LANGUAGE_CODE=de-DE
GOOGLE_CLOUD_TTS_VOICE_NAME=de-DE-Chirp3-HD-Kore
GOOGLE_CLOUD_TTS_ENDPOINT=https://texttospeech.googleapis.com/v1/text:synthesize
GOOGLE_CLOUD_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_CLOUD_TTS_SPEAKING_RATE=1.0
GOOGLE_CLOUD_TTS_PITCH=0.0

# Speech synthesis selection. Audio generation is optional; the app runs without it.
SPEECH_DEFAULT_PROVIDER=google_cloud_tts
SPEECH_DEFAULT_OUTPUT_FORMAT=wav
SPEECH_STORAGE_DISK=public

# Optional native audio generation via Gemini Live (GeminiLiveNativeAudioService).
# Leave SPEECH_GEMINI_NATIVE_API_KEY empty to keep this provider disabled.
SPEECH_GEMINI_NATIVE_API_KEY=
SPEECH_GEMINI_NATIVE_BEARER_TOKEN=
SPEECH_GEMINI_NATIVE_ENDPOINT=
SPEECH_GEMINI_NATIVE_MODEL=gemini-2.5-flash-preview-tts
SPEECH_GEMINI_NATIVE_MIME_TYPE=audio/wav
SPEECH_GEMINI_NATIVE_TEMPERATURE=
SPEECH_GEMINI_NATIVE_CONNECT_TIMEOUT_SECONDS=
SPEECH_GEMINI_NATIVE_REQUEST_TIMEOUT_SECONDS=
# Voice presets (optional). See config/services.php for the full list.
SPEECH_GEMINI_NATIVE_PRESET_NEUTRAL_FEMALE_VOICE=
SPEECH_GEMINI_NATIVE_PRESET_NEUTRAL_MALE_VOICE=
SPEECH_GEMINI_NATIVE_PRESET_NEWS_FEMALE_VOICE=
SPEECH_GEMINI_NATIVE_PRESET_NEWS_MALE_VOICE=
